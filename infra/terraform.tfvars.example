# terraform.tfvars.example
# Copy file này thành terraform.tfvars và điền giá trị thực

aws_region   = "ap-southeast-1"
account_id   = "YOUR_AWS_ACCOUNT_ID"
project_name = "sosflow"
environment  = "demo"

availability_zones = ["ap-southeast-1a", "ap-southeast-1b"]
vpc_cidr           = "10.0.0.0/16"

ec2_instance_type = "t3.small"
ec2_key_pair_name = ""   # Để trống để dùng SSM

db_instance_class = "db.t3.micro"
db_name           = "sosflow"
db_username       = "sosflow"

redis_node_type = "cache.t3.micro"

bedrock_model_id              = "amazon.nova-lite-v1:0"
bedrock_inference_profile_arn = "arn:aws:bedrock:REGION:ACCOUNT:inference-profile/apac.amazon.nova-lite-v1:0"
bedrock_timeout_seconds       = 12
bedrock_max_retries           = 2
ai_fallback_enabled           = true

demo_mode       = true
demo_token      = "CHANGE_ME_RANDOM_TOKEN"
seed_on_startup = true
