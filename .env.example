# SOSFlow local/demo configuration. Copy to .env and never commit real secrets.
DEMO_MODE=true
DEMO_TOKEN=change-this-demo-token

# mock works without AWS; bedrock uses the boto3 default credential chain.
AI_PROVIDER=mock
AWS_REGION=ap-southeast-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_INFERENCE_PROFILE_ARN=
BEDROCK_CUSTOM_MODEL_ARN=
BEDROCK_TIMEOUT_SECONDS=12
BEDROCK_MAX_RETRIES=2
AI_FALLBACK_ENABLED=true

# Local Docker can use ~/.aws/credentials through the read-only mount in
# docker-compose.local-demo.yml. Production must use an ECS task IAM role.
AWS_PROFILE=default

# Optional overrides for non-Compose backend execution.
DATABASE_URL=sqlite:///./sosflow.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
PRIORITY_RULES_PATH=../config/priority-rules.yaml
SEED_ON_STARTUP=true
