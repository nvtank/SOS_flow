# AWS Bedrock configuration
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
# If your Bedrock model requires an inference profile, set that here instead of BEDROCK_MODEL_ID
BEDROCK_INFERENCE_PROFILE_ID=arn:aws:bedrock:ap-southeast-1:197826770971:inference-profile/apac.amazon.nova-lite-v1:0
AWS_REGION=ap-southeast-1
# AWS_DEFAULT_REGION can be used as a fallback if AWS_REGION is not set
AWS_DEFAULT_REGION=ap-southeast-1

# Max tokens for Bedrock response
BEDROCK_MAX_TOKENS=2048

# Local AI mode: mock, hybrid, or bedrock
SOSFLOW_AI_MODE=bedrock
