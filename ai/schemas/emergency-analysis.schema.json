{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EmergencyAnalysis",
  "type": "object",
  "required": ["summary", "normalized_message", "extracted_location", "needs", "detected_risks", "missing_information", "confidence", "explanation"],
  "properties": {
    "summary": {"type": "string"},
    "normalized_message": {"type": "string"},
    "extracted_location": {
      "type": "object",
      "properties": {
        "raw_text": {"type": ["string", "null"]}, "province": {"type": ["string", "null"]},
        "district": {"type": ["string", "null"]}, "commune": {"type": ["string", "null"]}, "village": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "number_of_people": {"type": ["integer", "null"], "minimum": 0},
    "number_of_children": {"type": ["integer", "null"], "minimum": 0},
    "number_of_elderly": {"type": ["integer", "null"], "minimum": 0},
    "number_of_injured": {"type": ["integer", "null"], "minimum": 0},
    "is_trapped": {"type": ["boolean", "null"]},
    "water_level": {"type": ["number", "null"], "minimum": 0},
    "needs": {"type": "array", "items": {"type": "string"}},
    "detected_risks": {"type": "array", "items": {"type": "string"}},
    "missing_information": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "explanation": {"type": "string"}
  },
  "additionalProperties": false
}
